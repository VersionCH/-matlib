% 判断矩阵一致性检验脚本
A = input("判断矩阵A=");
[n,n] = size(A);
V = eig(A);
Max_eig = max(V);

% 随机一致性指标RI表
RI = [0, 0.0001, 0.52, 0.89, 1.12, 1.26, 1.41, 1.46, 1.49, 1.52, 1.54, 1.56, 1.58, 1.59];
CI = (Max_eig - n) / (n - 1);
CR = CI / RI(n);

disp("一致性指标CI=");
disp(CI);
disp("一致性比率CR=");
disp(CR);

if CR < 0.10
    disp("CR<0.10，该判断矩阵一致性可以接受");
else
    disp("CR≥0.10，该判断矩阵一致性不满足要求，矩阵需修改");
end
